# JWT signing secret. Use any random string for the demo.
JWT_SECRET=demo-secret-change-me

# Anthropic API key. Held server-side; the desktop never sees it.
ANTHROPIC_API_KEY=sk-ant-...

# AWS credentials with s3:PutObject + s3:GetObject on the bucket below.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 bucket for shared notes. If unset, S3 endpoints return 503 but everything
# else works (notes are stored inline in store.json).
S3_BUCKET=

# ---------------------------------------------------------------------------
# Google OIDC (single-tenant SSO)
# ---------------------------------------------------------------------------
# Create a Google Cloud project, enable OAuth consent screen (External /
# Testing is fine for dev), and create a 'Web application' OAuth client.
# Add http://127.0.0.1 as a redirect URI base — Google accepts any
# 127.0.0.1:<port> for installed-app flows (RFC 8252 loopback).
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=

# Comma-separated list of org_ids (typically email domains) allowed to sign
# in. The adapter rejects all other domains with 403 even after a valid
# Google ID token. Leave blank to allow any domain.
ORG_ID_ALLOWLIST=enam.co

# When true, accept personal Gmail / consumer accounts (no `hd` claim) by
# falling back to the email-domain after `@` as the org_id. Turn OFF in
# production — personal accounts have no admin control plane.
OIDC_ALLOW_NON_WORKSPACE=true
