---
import { ChatWithNotesImage, AiNotepadImage } from "../components/FeatureDemos";

// Shared "Steno mark" path group, reused by the Sovereign AI + AI-agent SVG cards.
// Coordinates are pre-scaled from brand/mark.svg's 0-450 box down to this
// component's native 0-64 box so the cards' translate(-32,-32)/scale() calibration applies.
const STENO_MARK_PATH =
  "M29.788 23.729C30.814 25.425 31.067 27.586 31.206 30.298C31.207 30.312 31.206 30.325 31.205 30.339C30.548 37.522 29.323 44.691 30.279 48.245C30.799 50.173 31.326 51.934 31.68 53.5C31.758 53.841 32.283 53.83 32.356 53.488C32.752 51.638 33.447 49.84 33.939 48.245C34.742 45.64 33.392 37.357 32.945 30.319C33.087 27.98 32.91 25.961 34.293 23.729M28.298 21.32C24.005 16.354 20.139 12.746 13.257 12.853C6.374 12.959 8.102 16.478 10.525 18.769C12.948 21.06 20.143 22.66 26.194 22.531C23.509 22.669 28.667 22.458 18.649 22.737C8.641 23.016 8.522 31.872 18.159 29.829C18.177 29.825 18.197 29.819 18.214 29.811C23.966 27.325 26.771 25.234 31.101 20.434M32.945 17.848C39.613 10.248 24.373 9.394 30.923 17.706C34.248 22.005 32.375 20.775 40.537 27.201C48.7 33.627 64.944 25.04 38.657 22.595C41.311 22.657 42.975 22.908 45.184 22.418C61.786 18.235 57.405 6.749 40.182 17.281C38.157 18.67 37.258 19.586 35.89 21.355";

const STACK_LAYERS = [
  { label: "Audio", type: "audio", y: 50 },
  { label: "Transcript", type: "transcript", y: 100 },
  { label: "Local model", type: "model", y: 150 },
  { label: "Summary", type: "summary", y: 200 },
];

// Per-layer glyphs drawn to the left of each stack row's label. Stroke styling
// (colour / width / linecap) is applied by the wrapping <g> at the call site.
const STACK_GLYPHS = {
  audio: `<line x1="2" y1="6" x2="2" y2="12" /><line x1="6" y1="2" x2="6" y2="16" /><line x1="10" y1="4" x2="10" y2="14" /><line x1="14" y1="6" x2="14" y2="12" />`,
  transcript: `<line x1="1" y1="4" x2="17" y2="4" /><line x1="1" y1="9" x2="17" y2="9" /><line x1="1" y1="14" x2="11" y2="14" />`,
  model: `<rect x="4" y="4" width="10" height="10" rx="2" /><line x1="9" y1="0" x2="9" y2="4" /><line x1="9" y1="14" x2="9" y2="18" /><line x1="0" y1="9" x2="4" y2="9" /><line x1="14" y1="9" x2="18" y2="9" />`,
  summary: `<rect x="3" y="1" width="12" height="16" rx="2" /><line x1="6" y1="6" x2="12" y2="6" /><line x1="6" y1="9" x2="12" y2="9" /><line x1="6" y1="12" x2="10" y2="12" />`,
};

const LANG_ROWS = [
  ["English", "Español", "中文", "Français", "Deutsch", "Português", "日本語", "한국어", "Italiano", "Русский"],
  ["العربية", "Nederlands", "Polski", "Türkçe", "Українська", "Ελληνικά", "हिंदी", "Tiếng Việt", "Čeština", "Svenska"],
  ["Română", "Norsk", "Dansk", "Suomi", "Magyar", "Català", "Bahasa", "தமிழ்", "বাংলা", "Afrikaans"],
];
const ROW_SPEEDS = [45, 38, 52];

const AI_SPOKES = [
  { id: "spoke-claude",  d: "M150 102 C150 136, 65 136, 65 170",  delay: 0 },
  { id: "spoke-chatgpt", d: "M150 102 L150 170",                   delay: 0.8 },
  { id: "spoke-gemini",  d: "M150 102 C150 136, 235 136, 235 170", delay: 1.6 },
];

// Pentagon of badges around the center hub, 72° apart starting from the top.
const MEETING_BADGES = [
  { id: "spoke-meet",     key: "googlemeet", cx: 150.0,  cy: 45.0,   delay: 0 },
  { id: "spoke-zoom",     key: "zoom",       cx: 240.35, cy: 110.64, delay: 0.48 },
  { id: "spoke-teams",    key: "teams",      cx: 205.84, cy: 216.86, delay: 0.96 },
  { id: "spoke-slack",    key: "slack",      cx: 94.16,  cy: 216.86, delay: 1.44 },
  { id: "spoke-inperson", key: "inperson",   cx: 59.65,  cy: 110.64, delay: 1.92 },
];

// Official app-icon marks for each platform, downloaded from each brand's own
// asset source (Zoom app icon MIT-licensed via Garuda Technology's sketch-icons;
// Google Meet, Microsoft Teams and Slack are each brand's current official app icon).
// Gradient/mask/filter ids are namespaced per brand to avoid collisions when several
// are inlined on the same page. Colors are unmodified from the source files.
const MEETING_LOGOS = {
  googlemeet: {
    w: 22,
    h: 17.25,
    svg: `<svg width="22" height="17.25" fill="none" viewBox="0 0 176 138" xmlns="http://www.w3.org/2000/svg"><path fill="url(#gmeet-a)" d="M 102.015,81.88 C 95.186,77.162 95.094,67.102 101.836,62.26 L 157,22.643 c 7.94,-5.701 19,-0.038 19,9.737 v 77.755 c 0,9.675 -10.861,15.359 -18.821,9.859 z" style="fill:url(#gmeet-a)" /><path fill="url(#gmeet-b)" d="M 0,44 C 0,19.7 19.7,0 44,0 h 64 c 11.046,0 20,8.954 20,20 v 98 c 0,11.046 -8.954,20 -20,20 H 20 C 8.9539999,138 0,129.046 0,118 Z" style="fill:url(#gmeet-b)" /><mask id="gmeet-e" width="129" height="138" x="8" y="27" maskUnits="userSpaceOnUse"><path fill="#ffffff" d="M 8,71 C 8,46.7 27.7,27 52,27 h 64 c 11.046,0 20,8.954 20,20 v 98 c 0,11.046 -8.954,20 -20,20 H 28 C 16.954,165 8,156.046 8,145 Z" /></mask><g filter="url(#gmeet-c)" mask="url(#gmeet-e)" transform="translate(-8,-27)"><path fill="url(#gmeet-f)" d="M 73.906,99.198 183.906,36 v 124 z" style="fill:url(#gmeet-f)" /></g><circle cx="30" cy="108" r="14" fill="#ffffff" /><defs><linearGradient id="gmeet-a" x1="128.8" x2="227.2" y1="104.44" y2="104.44" gradientUnits="userSpaceOnUse" gradientTransform="translate(-8,-27)"><stop stop-color="#f6a100" /><stop offset="1" stop-color="#ffbe00" /></linearGradient><linearGradient id="gmeet-f" x1="136.22" x2="78.5" y1="91.32" y2="91.190002" gradientUnits="userSpaceOnUse"><stop offset=".15" stop-color="#ffb5e8" /><stop offset="1" stop-color="#ffdbf5" stop-opacity="0" /></linearGradient><radialGradient id="gmeet-b" cx="0" cy="0" r="1" gradientTransform="matrix(-159.725,0,0,-135.852,152.325,69)" gradientUnits="userSpaceOnUse"><stop offset=".15" stop-color="#ffe921" /><stop offset="1" stop-color="#fec700" /></radialGradient><filter id="gmeet-c" width="166" height="180" x="45.91" y="8" color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse"><feFlood flood-opacity="0" result="BackgroundImageFix" /><feBlend in="SourceGraphic" in2="BackgroundImageFix" result="shape" mode="normal" /><feGaussianBlur result="effect1_foregroundBlur_37584_9338" stdDeviation="14" /></filter></defs></svg>`,
  },
  zoom: {
    w: 22,
    h: 22,
    svg: `<svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 11.6C2 8.23969 2 6.55953 2.65396 5.27606C3.2292 4.14708 4.14708 3.2292 5.27606 2.65396C6.55953 2 8.23969 2 11.6 2H20.4C23.7603 2 25.4405 2 26.7239 2.65396C27.8529 3.2292 28.7708 4.14708 29.346 5.27606C30 6.55953 30 8.23969 30 11.6V20.4C30 23.7603 30 25.4405 29.346 26.7239C28.7708 27.8529 27.8529 28.7708 26.7239 29.346C25.4405 30 23.7603 30 20.4 30H11.6C8.23969 30 6.55953 30 5.27606 29.346C4.14708 28.7708 3.2292 27.8529 2.65396 26.7239C2 25.4405 2 23.7603 2 20.4V11.6Z" fill="#4087FC"/><path d="M8.26667 10C7.56711 10 7 10.6396 7 11.4286V18.3571C7 20.369 8.44612 22 10.23 22L17.7333 21.9286C18.4329 21.9286 19 21.289 19 20.5V13.5C19 11.4881 17.2839 10 15.5 10L8.26667 10Z" fill="white"/><path d="M20.7122 12.7276C20.2596 13.1752 20 13.8211 20 14.5V17.3993C20 18.0782 20.2596 18.7242 20.7122 19.1717L23.5288 21.6525C24.1019 22.2191 25 21.7601 25 20.9005V11.1352C25 10.2755 24.1019 9.81654 23.5288 10.3832L20.7122 12.7276Z" fill="white"/></svg>`,
  },
  teams: {
    w: 20.84,
    h: 22,
    svg: `<svg width="20.84" height="22" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="4 4 36 38"><path fill="url(#msteams-a)" d="M21.9999 20h12c3.3137 0 6 2.6863 6 6v10c0 3.3137-2.6863 6-6 6s-6-2.6863-6-6V26c0-3.3137-2.6863-6-6-6"/><path fill="url(#msteams-b)" d="M7.99988 24c0-3.3137 2.68632-6 6.00002-6h8c3.3137 0 6 2.6863 6 6v12c0 3.3137 2.6863 6 6 6l-16.0001-.0001c-5.5228 0-9.99992-4.4771-9.99992-10z"/><path fill="url(#msteams-c)" fill-opacity=".7" d="M7.99988 24c0-3.3137 2.68632-6 6.00002-6h8c3.3137 0 6 2.6863 6 6v12c0 3.3137 2.6863 6 6 6l-16.0001-.0001c-5.5228 0-9.99992-4.4771-9.99992-10z"/><path fill="url(#msteams-d)" fill-opacity=".7" d="M7.99988 24c0-3.3137 2.68632-6 6.00002-6h8c3.3137 0 6 2.6863 6 6v12c0 3.3137 2.6863 6 6 6l-16.0001-.0001c-5.5228 0-9.99992-4.4771-9.99992-10z"/><path fill="url(#msteams-e)" d="M32.9999 18c2.7614 0 5-2.2386 5-5s-2.2386-5-5-5-5 2.2386-5 5 2.2386 5 5 5"/><path fill="url(#msteams-f)" fill-opacity=".46" d="M32.9999 18c2.7614 0 5-2.2386 5-5s-2.2386-5-5-5-5 2.2386-5 5 2.2386 5 5 5"/><path fill="url(#msteams-g)" fill-opacity=".4" d="M32.9999 18c2.7614 0 5-2.2386 5-5s-2.2386-5-5-5-5 2.2386-5 5 2.2386 5 5 5"/><path fill="url(#msteams-h)" d="M17.9999 16c3.3137 0 6-2.6863 6-6 0-3.31371-2.6863-6-6-6s-6 2.68629-6 6c0 3.3137 2.6863 6 6 6"/><path fill="url(#msteams-i)" fill-opacity=".6" d="M17.9999 16c3.3137 0 6-2.6863 6-6 0-3.31371-2.6863-6-6-6s-6 2.68629-6 6c0 3.3137 2.6863 6 6 6"/><path fill="url(#msteams-j)" fill-opacity=".5" d="M17.9999 16c3.3137 0 6-2.6863 6-6 0-3.31371-2.6863-6-6-6s-6 2.68629-6 6c0 3.3137 2.6863 6 6 6"/><rect width="16" height="16" x="4" y="23" fill="url(#msteams-k)" rx="3.25"/><rect width="16" height="16" x="4" y="23" fill="url(#msteams-l)" fill-opacity=".7" rx="3.25"/><path fill="#fff" d="M15.4792 28.1054h-2.4471v7.466h-2.0648v-7.466H8.52014v-1.6768h6.95906z"/><defs><radialGradient id="msteams-a" cx="0" cy="0" r="1" gradientTransform="matrix(13.4784 0 0 33.2694 39.7967 22.1739)" gradientUnits="userSpaceOnUse"><stop stop-color="#a98aff"/><stop offset=".14" stop-color="#8c75ff"/><stop offset=".565" stop-color="#5f50e2"/><stop offset=".9" stop-color="#3c2cb8"/></radialGradient><radialGradient id="msteams-b" cx="0" cy="0" r="1" gradientTransform="rotate(68.1539 -7.71566095 14.71355834)scale(32.752 33.1231)" gradientUnits="userSpaceOnUse"><stop stop-color="#85c2ff"/><stop offset=".69" stop-color="#7588ff"/><stop offset="1" stop-color="#6459fe"/></radialGradient><radialGradient id="msteams-d" cx="0" cy="0" r="1" gradientTransform="rotate(113.326 8.09285255 17.64474501)scale(19.2186 15.4273)" gradientUnits="userSpaceOnUse"><stop stop-color="#bd96ff"/><stop offset=".686685" stop-color="#bd96ff" stop-opacity="0"/></radialGradient><radialGradient id="msteams-e" cx="0" cy="0" r="1" gradientTransform="matrix(0 -10 12.6216 0 32.9999 11.5714)" gradientUnits="userSpaceOnUse"><stop offset=".268201" stop-color="#6868f7"/><stop offset="1" stop-color="#3923b1"/></radialGradient><radialGradient id="msteams-f" cx="0" cy="0" r="1" gradientTransform="rotate(40.0516 -.03068196 44.8729095)scale(7.14629 10.3363)" gradientUnits="userSpaceOnUse"><stop offset=".270711" stop-color="#a1d3ff"/><stop offset=".813393" stop-color="#a1d3ff" stop-opacity="0"/></radialGradient><radialGradient id="msteams-g" cx="0" cy="0" r="1" gradientTransform="rotate(-41.6581 32.11799918 -43.41948423)scale(8.51275 20.8824)" gradientUnits="userSpaceOnUse"><stop stop-color="#e3acfd"/><stop offset=".816041" stop-color="#9fa2ff" stop-opacity="0"/></radialGradient><radialGradient id="msteams-h" cx="0" cy="0" r="1" gradientTransform="matrix(0 -12 15.146 0 17.9999 8.28571)" gradientUnits="userSpaceOnUse"><stop offset=".268201" stop-color="#8282ff"/><stop offset="1" stop-color="#3923b1"/></radialGradient><radialGradient id="msteams-i" cx="0" cy="0" r="1" gradientTransform="rotate(40.0516 -3.15465147 21.41641466)scale(8.57554 12.4035)" gradientUnits="userSpaceOnUse"><stop offset=".270711" stop-color="#a1d3ff"/><stop offset=".813393" stop-color="#a1d3ff" stop-opacity="0"/></radialGradient><radialGradient id="msteams-j" cx="0" cy="0" r="1" gradientTransform="rotate(-41.6581 20.38180375 -26.51566158)scale(10.2153 25.0589)" gradientUnits="userSpaceOnUse"><stop stop-color="#e3acfd"/><stop offset=".816041" stop-color="#9fa2ff" stop-opacity="0"/></radialGradient><radialGradient id="msteams-k" cx="0" cy="0" r="1" gradientTransform="rotate(45 -25.76345597 16.32842712)scale(22.6274)" gradientUnits="userSpaceOnUse"><stop offset=".046875" stop-color="#688eff"/><stop offset=".946875" stop-color="#230f94"/></radialGradient><radialGradient id="msteams-l" cx="0" cy="0" r="1" gradientTransform="matrix(0 11.2 -13.0702 0 12 32.6)" gradientUnits="userSpaceOnUse"><stop offset=".570647" stop-color="#6965f6" stop-opacity="0"/><stop offset="1" stop-color="#8f8fff"/></radialGradient><linearGradient id="msteams-c" x1="20.5936" x2="20.5936" y1="18" y2="42" gradientUnits="userSpaceOnUse"><stop offset=".801159" stop-color="#6864f6" stop-opacity="0"/><stop offset="1" stop-color="#5149de"/></linearGradient></defs></svg>`,
  },
  slack: {
    w: 16,
    h: 16,
    svg: `<svg width="16" height="16" viewBox="0 0 127 127" xmlns="http://www.w3.org/2000/svg"><path d="M27.2 80c0 7.3-5.9 13.2-13.2 13.2C6.7 93.2.8 87.3.8 80c0-7.3 5.9-13.2 13.2-13.2h13.2V80zm6.6 0c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2v33c0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V80z" fill="#E01E5A"/><path d="M47 27c-7.3 0-13.2-5.9-13.2-13.2C33.8 6.5 39.7.6 47 .6c7.3 0 13.2 5.9 13.2 13.2V27H47zm0 6.7c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H13.9C6.6 60.1.7 54.2.7 46.9c0-7.3 5.9-13.2 13.2-13.2H47z" fill="#36C5F0"/><path d="M99.9 46.9c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H99.9V46.9zm-6.6 0c0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V13.8C66.9 6.5 72.8.6 80.1.6c7.3 0 13.2 5.9 13.2 13.2v33.1z" fill="#2EB67D"/><path d="M80.1 99.8c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V99.8h13.2zm0-6.6c-7.3 0-13.2-5.9-13.2-13.2 0-7.3 5.9-13.2 13.2-13.2h33.1c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H80.1z" fill="#ECB22E"/></svg>`,
  },
  inperson: {
    w: 18,
    h: 18,
    svg: `<svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="var(--fg-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><path d="M16 3.128a4 4 0 0 1 0 7.744" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><circle cx="9" cy="7" r="4" /></svg>`,
  },
};

const CODE_LINES = [
  { text: "def summarize(text):", y: 64, opacity: 0.92 },
  { text: "    # on-device only", y: 94, opacity: 0.4 },
  { text: "    model = load()", y: 124, opacity: 0.72 },
  { text: "    return model(text)", y: 154, opacity: 0.72 },
  { text: "# MIT licensed", y: 214, opacity: 0.4 },
];

const FEATURES = [
  { kind: "no-meeting-bots", title: "No meeting bots", body: "No bot joins your call, no unfamiliar face waiting in the room. Steno listens through your system audio instead — the meeting looks exactly like it always does.", wide: true },
  { kind: "works-with-any-meeting", title: "Works with any meeting", body: "Zoom, Google Meet, Microsoft Teams, Slack huddles. Steno works the same way every time." },
  { kind: "sovereign-ai", title: "Sovereign AI", body: "You own the entire stack — models and data stay on your device or network, under your control. Works offline on planes, in hospitals, in restricted areas." },
  { kind: "chat-with-notes", title: "Chat with your notes", body: "Ask questions across any note or recording. Surface decisions, action items, and key themes instantly.", wide: true },
  { kind: "no-data-leaves", title: "No data leaves", body: "Zero network requests after install. Your device is functionally air-gapped from the moment you launch it." },
  { kind: "ai-notepad", title: "AI notepad", body: "Jot notes during a recording. They're merged with the transcript to shape the AI summary." },
  { kind: "languages", title: "99 languages", body: "Whisper auto-detects the language spoken. Works equally well across multilingual meetings." },
  { kind: "open-source", title: "Open source", body: "Every line of code is public. Audit it yourself, fork it, or verify our privacy claims — nothing is hidden behind a black box." },
  { kind: "ai-agent", title: "AI agent ready", body: "Summaries and notes save as plain Markdown. Pipe into any AI agent, vault, or workflow your team already runs.", wide: true },
];
---

<section id="features" class="sect" style={{ background: "var(--surface-sunken)" }}>
  <div class="container-site">
    <div class="mb-[48px] md:mb-[72px]" style="max-width: 640px">
      <h2
        style={{
          fontFamily: "var(--font-serif)",
          fontWeight: 400,
          fontSize: "clamp(34px, 4.6vw, 52px)",
          lineHeight: 1.08,
          letterSpacing: "-0.02em",
          color: "var(--fg-1)",
          margin: "0 0 18px",
        }}
      >
        Built for focus. Engineered for privacy.
      </h2>
      <p class="text-fg-2 text-lg leading-[1.55]" style="max-width: 56ch">
        Every capability is designed around one principle: your audio never leaves your device.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {FEATURES.map(({ kind, title, body, wide }) => (
        <div
          class:list={["flex flex-col overflow-hidden", wide && "sm:col-span-2 lg:col-span-2"]}
          style={{ borderRadius: 14, border: "1px solid var(--border)", background: "var(--surface-raised)" }}
        >
          <div
            aria-hidden="true"
            style={{ height: "clamp(180px, 45vw, 320px)", position: "relative", overflow: "hidden", background: "var(--surface-raised)" }}
          >
            {kind === "chat-with-notes" && <ChatWithNotesImage client:visible />}
            {kind === "ai-notepad" && <AiNotepadImage client:visible />}

            {kind === "no-meeting-bots" && (
              <div
                style={{
                  position: "absolute",
                  inset: "28px",
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                }}
              >
                <img
                  src="/images/no-meeting-bots.jpg"
                  alt="A video call between two people, with no recording bot present in the call"
                  width="1400"
                  height="886"
                  loading="lazy"
                  decoding="async"
                  style={{
                    maxWidth: "100%",
                    maxHeight: "100%",
                    width: "auto",
                    height: "auto",
                    borderRadius: 10,
                    border: "1px solid var(--border-subtle)",
                    boxShadow: "0 4px 24px rgba(27,27,25,0.12), 0 1px 4px rgba(27,27,25,0.06)",
                    display: "block",
                  }}
                />
              </div>
            )}

            {kind === "works-with-any-meeting" && (
              <svg viewBox="0 0 300 285" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style={{ display: "block" }}>
                <defs>
                  {MEETING_BADGES.map(({ id, cx, cy }) => (
                    <path id={id} d={`M${cx} ${cy} L150 140`} fill="none" />
                  ))}
                </defs>
                {MEETING_BADGES.map(({ cx, cy }) => (
                  <path d={`M150 140 L${cx} ${cy}`} stroke="var(--border)" stroke-width="1.5" fill="none" />
                ))}
                {MEETING_BADGES.map(({ id, delay }) => (
                  <circle r="3" fill="#8A8A83">
                    <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.4s" begin={`${delay}s`} repeatCount="indefinite" />
                    <animateMotion dur="2.4s" begin={`${delay}s`} repeatCount="indefinite" calcMode="linear">
                      <mpath href={`#${id}`} />
                    </animateMotion>
                  </circle>
                ))}
                {MEETING_BADGES.map(({ key, cx, cy }) => {
                  const logo = MEETING_LOGOS[key];
                  return (
                    <>
                      <rect x={cx - 23} y={cy - 23} width="46" height="46" rx="11" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1" />
                      <g transform={`translate(${cx - logo.w / 2},${cy - logo.h / 2})`} set:html={logo.svg} />
                    </>
                  );
                })}
                <rect x="127" y="117" width="46" height="46" rx="11" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1" />
                <g transform="translate(150,140) scale(0.47)" stroke="var(--fg-1)" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" fill="none">
                  <g transform="translate(-32,-32)">
                    <path d={STENO_MARK_PATH} />
                  </g>
                </g>
              </svg>
            )}

            {kind === "sovereign-ai" && (
              <svg viewBox="0 0 300 285" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style={{ display: "block" }}>
                <defs>
                  <linearGradient id="stack-glow" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--fg-1)" stop-opacity="0" />
                    <stop offset="50%" stop-color="var(--fg-1)" stop-opacity="0.07" />
                    <stop offset="100%" stop-color="var(--fg-1)" stop-opacity="0" />
                  </linearGradient>
                  <clipPath id="stack-clip">
                    <rect x="48" y="34" width="204" height="218" rx="16" />
                  </clipPath>
                </defs>
                <rect x="48" y="34" width="204" height="218" rx="16" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1.5" />
                {STACK_LAYERS.map(({ label, type, y }) => (
                  <g>
                    <rect x="64" y={y} width="172" height="36" rx="10" fill="var(--surface-hover)" stroke="var(--border-subtle)" stroke-width="1" />
                    <g transform={`translate(76,${y + 9})`} stroke="var(--fg-2)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none" set:html={STACK_GLYPHS[type]} />
                    <text x="104" y={y + 18} dominant-baseline="central" font-size="13" font-weight="500" fill="var(--fg-1)" font-family="var(--font-sans)">
                      {label}
                    </text>
                  </g>
                ))}
                <g clip-path="url(#stack-clip)">
                  <rect x="48" y="-70" width="204" height="70" fill="url(#stack-glow)">
                    <animate attributeName="y" values="-70;-70;252;252;-70" keyTimes="0;0.05;0.65;0.75;1" dur="4.5s" repeatCount="indefinite" />
                  </rect>
                </g>
                <rect x="48" y="34" width="204" height="218" rx="16" fill="none" stroke="var(--border)" stroke-width="1.5" />
                <circle cx="252" cy="34" r="18" fill="var(--surface-raised)" />
                <circle cx="252" cy="34" r="15" fill="#1B1B19" />
                <g transform="translate(252,34)">
                  <path d="M-4,-1 v-3 a4,4 0 0 1 8,0 v3" stroke="#EDEAE0" stroke-width="1.8" fill="none" stroke-linecap="round" />
                  <rect x="-6" y="-1" width="12" height="10" rx="2" fill="#EDEAE0" />
                  <circle cx="0" cy="3.2" r="1.1" fill="#1B1B19" />
                </g>
              </svg>
            )}

            {kind === "no-data-leaves" && (
              <svg viewBox="0 0 300 285" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style={{ display: "block" }}>
                <defs>
                  <radialGradient id="nodata-glow" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="var(--fg-1)" stop-opacity="0.1" />
                    <stop offset="65%" stop-color="var(--fg-1)" stop-opacity="0.04" />
                    <stop offset="100%" stop-color="var(--fg-1)" stop-opacity="0" />
                  </radialGradient>
                </defs>
                <circle cx="150" cy="140" r="88" fill="url(#nodata-glow)">
                  <animate attributeName="r" values="60;92;60" dur="5s" calcMode="spline" keySplines="0.42 0 0.58 1;0.42 0 0.58 1" repeatCount="indefinite" />
                </circle>
                <circle cx="150" cy="140" r="72" fill="none" stroke="var(--border-strong)" stroke-width="1.2">
                  <animate attributeName="r" values="56;80;56" dur="5s" calcMode="spline" keySplines="0.42 0 0.58 1;0.42 0 0.58 1" repeatCount="indefinite" />
                  <animate attributeName="stroke-opacity" values="0.35;0.8;0.35" dur="5s" calcMode="spline" keySplines="0.42 0 0.58 1;0.42 0 0.58 1" repeatCount="indefinite" />
                </circle>
                <g transform="translate(150,140) scale(0.75)" stroke="var(--fg-1)" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" fill="none">
                  <g transform="translate(-32,-32)">
                    <path d={STENO_MARK_PATH} />
                  </g>
                </g>
              </svg>
            )}

            {kind === "languages" && (
              <div style={{ width: "100%", height: "100%", display: "flex", flexDirection: "column", justifyContent: "center", gap: 10, overflow: "hidden" }}>
                {LANG_ROWS.map((langs, i) => {
                  const rtl = i % 2 === 1;
                  const doubled = [...langs, ...langs];
                  return (
                    <div
                      style={{
                        overflow: "hidden",
                        maskImage: "linear-gradient(to right, transparent, black 16%, black 84%, transparent)",
                        WebkitMaskImage: "linear-gradient(to right, transparent, black 16%, black 84%, transparent)",
                      }}
                    >
                      <div style={{ display: "flex", gap: 8, width: "max-content", animation: `${rtl ? "marqueeRTL" : "marqueeLTR"} ${ROW_SPEEDS[i]}s linear infinite` }}>
                        {doubled.map((lang) => (
                          <span style={{ display: "inline-block", padding: "5px 14px", borderRadius: 20, background: "var(--surface-hover)", border: "1px solid var(--border-subtle)", fontSize: 12, fontWeight: 500, color: "var(--fg-2)", whiteSpace: "nowrap" }}>
                            {lang}
                          </span>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            )}

            {kind === "ai-agent" && (
              <svg viewBox="0 0 300 285" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style={{ display: "block" }}>
                <defs>
                  {AI_SPOKES.map(({ id, d }) => (
                    <path id={id} d={d} fill="none" />
                  ))}
                  <linearGradient id="gem-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#4285F4" />
                    <stop offset="100%" stop-color="#9B5CF6" />
                  </linearGradient>
                </defs>
                {AI_SPOKES.map(({ id, d }) => (
                  <path d={d} stroke="var(--border)" stroke-width="1.5" fill="none" />
                ))}
                {AI_SPOKES.map(({ id, delay }) => (
                  <circle r="3" fill="#8A8A83">
                    <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.4s" begin={`${delay}s`} repeatCount="indefinite" />
                    <animateMotion dur="2.4s" begin={`${delay}s`} repeatCount="indefinite" calcMode="linear">
                      <mpath href={`#${id}`} />
                    </animateMotion>
                  </circle>
                ))}
                <rect x="120" y="40" width="60" height="60" rx="13" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1" />
                <g transform="translate(150,70) scale(0.47)" stroke="var(--fg-1)" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" fill="none">
                  <g transform="translate(-32,-32)">
                    <path d={STENO_MARK_PATH} />
                  </g>
                </g>
                <rect x="42" y="170" width="46" height="46" rx="11" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1" />
                <g transform="translate(53,181)" fill="#D97757">
                  <path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z" />
                </g>
                <rect x="127" y="170" width="46" height="46" rx="11" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1" />
                <g transform="translate(138,181)" fill="var(--fg-1)">
                  <path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z" />
                </g>
                <rect x="212" y="170" width="46" height="46" rx="11" fill="var(--surface-raised)" stroke="var(--border)" stroke-width="1" />
                <g transform="translate(223,181)">
                  <path
                    d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58 12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96 2.19.93 3.81 2.55t2.55 3.81"
                    fill="url(#gem-grad)"
                  />
                </g>
              </svg>
            )}

            {kind === "open-source" && (
              <svg viewBox="0 0 300 285" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style={{ display: "block" }}>
                <defs>
                  <clipPath id="code-clip">
                    <rect x="48" y="34" width="204" height="218" rx="16" />
                  </clipPath>
                </defs>
                <rect x="48" y="34" width="204" height="218" rx="16" fill="var(--surface-hover)" stroke="var(--border)" stroke-width="1.5" />
                {CODE_LINES.map(({ text, y, opacity }) => (
                  <text x="64" y={y} font-family="var(--font-mono)" font-size="11.5" fill="var(--fg-1)" opacity={opacity}>
                    {text}
                  </text>
                ))}
                <g clip-path="url(#code-clip)">
                  <g>
                    <animateTransform attributeName="transform" type="translate" values="150,55; 150,225; 150,55" keyTimes="0;0.5;1" dur="4.5s" repeatCount="indefinite" />
                    <circle r="13" fill="rgba(27,27,25,0.05)" stroke="var(--fg-2)" stroke-width="1.8" />
                    <line x1="9.2" y1="9.2" x2="17" y2="17" stroke="var(--fg-2)" stroke-width="1.8" stroke-linecap="round" />
                  </g>
                </g>
                <circle cx="252" cy="34" r="18" fill="var(--surface-raised)" />
                <circle cx="252" cy="34" r="15" fill="#1B1B19" />
                <path d="M247,34 L250.5,38 L257,30.5" stroke="#EDEAE0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            )}
          </div>

          <div style={{ padding: "24px 28px 28px" }}>
            <h3 style={{ fontSize: 16, fontWeight: 600, color: "var(--fg-1)", margin: "0 0 8px" }}>
              {title}
            </h3>
            <p style={{ fontSize: 14, lineHeight: 1.6, color: "var(--fg-2)", margin: 0 }}>
              {body}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
