---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found — Steno"
  description="The page you're looking for doesn't exist."
  canonical="https://stenoai.co/404/"
>
  <main class="container-site" style="min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 16px;">
    <h1
      style={{
        fontFamily: "var(--font-serif)",
        fontWeight: 400,
        fontSize: "clamp(40px, 5.6vw, 68px)",
        letterSpacing: "-0.025em",
        color: "var(--fg-1)",
      }}
    >
      Page not found
    </h1>
    <p class="text-fg-2 text-lg">The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class="btn-base btn-primary inline-flex items-center gap-2 no-underline hover:no-underline mt-4">
      Back to home
    </a>
  </main>
</BaseLayout>
